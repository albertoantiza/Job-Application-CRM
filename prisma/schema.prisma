generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           Int           @id @default(autoincrement())
  name         String
  website      String?
  location     String?
  applications Application[]
  contacts     Contact[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id          Int          @id @default(autoincrement())
  companyId   Int?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  role        String
  status      String       @default("applied")
  interviews  Interview[]
  notes       Note[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([companyId])
}

model Contact {
  id          Int       @id @default(autoincrement())
  companyId   Int?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  email       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
}

model Interview {
  id            Int          @id @default(autoincrement())
  applicationId Int
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  date          DateTime
  stage         String
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([applicationId])
}

model Note {
  id            Int          @id @default(autoincrement())
  applicationId Int
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([applicationId])
}
