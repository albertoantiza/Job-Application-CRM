generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  name         String?
  role         Role          @default(user)
  companies    Company[]
  applications Application[]
  contacts     Contact[]
  interviews   Interview[]
  notes        Note[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Company {
  id           Int           @id @default(autoincrement())
  userId       Int
  user         User          @relation(fields: [userId], references: [id])
  name         String
  website      String?
  location     String?
  status       String        @default("active")
  applications Application[]
  contacts     Contact[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
}

model Application {
  id          Int          @id @default(autoincrement())
  userId      Int
  user        User         @relation(fields: [userId], references: [id])
  companyId   Int?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  role        String
  status      String       @default("applied")
  interviews  Interview[]
  notes       Note[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([companyId])
}

model Contact {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  companyId   Int?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  email       String
  status      String    @default("active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([companyId])
}

model Interview {
  id            Int          @id @default(autoincrement())
  userId        Int
  user          User         @relation(fields: [userId], references: [id])
  applicationId Int
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  date          DateTime
  stage         String
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([applicationId])
}

model Note {
  id            Int          @id @default(autoincrement())
  userId        Int
  user          User         @relation(fields: [userId], references: [id])
  applicationId Int
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([applicationId])
}
